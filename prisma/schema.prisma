generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  name               String
  role               String              @default("student")
  phone              String?
  photoUrl           String?
  darkMode           Boolean             @default(false)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  activityLogs       ActivityLog[]
  announcements      Announcement[]
  createdAssignments Assignment[]
  bookmarks          Bookmark[]
  calendarEvents     CalendarEvent[]
  chatMessages       ChatMessage[]
  chatParticipants   ChatParticipant[]
  discussionPosts    DiscussionPost[]
  bookReviews        LibraryBookReview[]
  createdMaterials   Material[]
  mediaLibrary       MediaItem[]
  notifications      Notification[]
  parent             Parent?
  createdQuizzes     Quiz[]
  student            Student?
  notes              StudentNote[]
  teacher            Teacher?
}

model Teacher {
  id                 String              @id @default(cuid())
  userId             String              @unique
  nip                String              @unique
  specialization     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classAdvisory      ClassAdvisor[]      @relation("ClassAdvisorTeacher")
  subjectAssignments SubjectAssignment[] @relation("SubjectAssignmentTeacher")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  nis                   String                 @unique
  parentPhone           String?
  faceRegistered        Boolean                @default(false)
  faceDescriptorUrl     String?
  status                String                 @default("active")
  classId               String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assignmentSubmissions AssignmentSubmission[]  @relation("StudentSubmissions")
  attendance            Attendance[]            @relation("StudentAttendance")
  grades                Grade[]                 @relation("StudentGrades")
  leaveRequests         LeaveRequest[]          @relation("StudentLeaveRequest")
  quizAttempts          QuizAttempt[]           @relation("StudentQuizAttempts")
  class                 Class                  @relation("StudentClass", fields: [classId], references: [id], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs             StudentAuditLog[]       @relation("StudentAuditLog")

  @@index([classId])
  @@index([status])
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  childId   String
  relation  String   @default("father")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AcademicYear {
  id         String       @id @default(cuid())
  name       String       @unique
  isActive   Boolean      @default(false)
  isArchived Boolean      @default(false)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]
  classes    Class[]
  semesters  Semester[]
  subjects   Subject[]
}

model Semester {
  id             String       @id @default(cuid())
  name           String
  academicYearId String
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  grades         Grade[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
}

model Class {
  id                 String              @id @default(cuid())
  name               String
  major              String?
  grade              String?
  academicYearId     String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  announcements      Announcement[]
  calendarEvents     CalendarEvent[]
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classAdvisors      ClassAdvisor[]      @relation("ClassAdvisorClass")
  discussionForums   DiscussionForum[]
  locationClass      LocationClass[]
  schedules          Schedule[]
  students           Student[]           @relation("StudentClass")
  subjectAssignments SubjectAssignment[] @relation("SubjectAssignmentClass")
}

model Subject {
  id                 String              @id @default(cuid())
  name               String
  code               String?
  description        String?
  academicYearId     String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignments        Assignment[]
  gradeCategories    GradeCategory[]
  materials          Material[]
  quizzes            Quiz[]
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subjectAssignments SubjectAssignment[] @relation("SubjectAssignmentSubject")
}

model SubjectAssignment {
  id               String            @id @default(cuid())
  subjectId        String
  teacherId        String
  classId          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  discussionForums DiscussionForum[]
  schedules        Schedule[]
  class            Class             @relation("SubjectAssignmentClass", fields: [classId], references: [id], onDelete: Cascade)
  subject          Subject           @relation("SubjectAssignmentSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  teacher          Teacher           @relation("SubjectAssignmentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([subjectId, teacherId, classId])
  @@index([classId])
  @@index([teacherId])
}

model ClassAdvisor {
  id             String   @id @default(cuid())
  teacherId      String
  classId        String
  academicYearId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  class          Class    @relation("ClassAdvisorClass", fields: [classId], references: [id], onDelete: Cascade)
  teacher        Teacher  @relation("ClassAdvisorTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
}

model Schedule {
  id                  String            @id @default(cuid())
  classId             String
  subjectAssignmentId String
  dayOfWeek           Int
  startTime           String
  endTime             String
  room                String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  class               Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectAssignment   SubjectAssignment @relation(fields: [subjectAssignmentId], references: [id], onDelete: Cascade)
}

model Material {
  id          String        @id @default(cuid())
  subjectId   String
  teacherId   String
  title       String
  description String?
  content     String?
  type        String        @default("document")
  fileUrl     String?
  videoUrl    String?
  topic       String?
  orderNum    Int           @default(0)
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  bookmarks   Bookmark[]
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  notes       StudentNote[]
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  materialId String
  createdAt  DateTime @default(now())
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
}

model StudentNote {
  id         String   @id @default(cuid())
  userId     String
  materialId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assignment {
  id              String                 @id @default(cuid())
  subjectId       String
  teacherId       String
  title           String
  description     String?
  instructions    String?
  dueDate         DateTime
  allowLateSubmit Boolean                @default(false)
  maxScore        Float                  @default(100)
  attachmentUrl   String?
  gradeCategoryId String?
  isPublished     Boolean                @default(false)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  gradeCategory   GradeCategory?         @relation(fields: [gradeCategoryId], references: [id], onDelete: SetNull)
  subject         Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher         User                   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions     AssignmentSubmission[]

  @@index([subjectId])
  @@index([teacherId])
  @@index([isPublished])
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  textContent  String?
  submittedAt  DateTime?
  status       String     @default("pending")
  score        Float?
  feedback     String?
  gradedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student    @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, status])
  @@index([studentId])
}

model Quiz {
  id                 String         @id @default(cuid())
  subjectId          String
  teacherId          String
  title              String
  description        String?
  duration           Int            @default(30)
  maxAttempts        Int            @default(1)
  isPublished        Boolean        @default(false)
  startDate          DateTime?
  endDate            DateTime?
  gradeCategoryId    String?
  isExam             Boolean        @default(false)
  shuffleQuestions   Boolean        @default(true)
  shuffleOptions     Boolean        @default(true)
  showResult         String         @default("after_exam")
  showCorrectAnswers Boolean        @default(false)
  tabSwitchLimit     Int            @default(3)
  passwordProtected  Boolean        @default(false)
  examPassword       String?
  autoSubmitOnCheat  Boolean        @default(true)
  token              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  gradeCategory      GradeCategory? @relation(fields: [gradeCategoryId], references: [id], onDelete: SetNull)
  subject            Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher            User           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  attempts           QuizAttempt[]
  questions          QuizQuestion[]

  @@index([subjectId])
  @@index([teacherId])
  @@index([isPublished])
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  question      String
  type          String       @default("multiple_choice")
  options       String?
  correctAnswer String?
  points        Float        @default(1)
  orderNum      Int          @default(0)
  explanation   String?
  imageUrl      String?
  answers       QuizAnswer[]
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id               String       @id @default(cuid())
  quizId           String
  studentId        String
  score            Float?
  status           String       @default("in_progress")
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  timeSpent        Int?
  tabSwitches      Int          @default(0)
  copyAttempts     Int          @default(0)
  pasteAttempts    Int          @default(0)
  rightClicks      Int          @default(0)
  fullscreenExited Int          @default(0)
  cheatLog         String?
  answers          QuizAnswer[]
  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student          Student      @relation("StudentQuizAttempts", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([quizId, status])
  @@index([studentId])
}

model QuizAnswer {
  id           String       @id @default(cuid())
  attemptId    String
  questionId   String
  answer       String?
  isCorrect    Boolean?
  pointsEarned Float        @default(0)
  attempt      QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model GradeCategory {
  id          String       @id @default(cuid())
  subjectId   String
  name        String
  weight      Float        @default(1.0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
  grades      Grade[]
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]
}

model Grade {
  id              String        @id @default(cuid())
  studentId       String
  gradeCategoryId String
  semesterId      String
  score           Float
  description     String?
  date            DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  gradeCategory   GradeCategory @relation(fields: [gradeCategoryId], references: [id], onDelete: Cascade)
  semester        Semester      @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  student         Student       @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([gradeCategoryId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  authorId    String
  classId     String?
  priority    String   @default("normal")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  class       Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([isPublished])
  @@index([classId])
}

model DiscussionForum {
  id                  String             @id @default(cuid())
  title               String
  description         String?
  classId             String
  subjectAssignmentId String?
  isPinned            Boolean            @default(false)
  isLocked            Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  class               Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectAssignment   SubjectAssignment? @relation(fields: [subjectAssignmentId], references: [id], onDelete: SetNull)
  posts               DiscussionPost[]
}

model DiscussionPost {
  id           String          @id @default(cuid())
  forumId      String
  authorId     String
  content      String
  parentPostId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum        DiscussionForum @relation(fields: [forumId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  content    String
  chatRoomId String
  createdAt  DateTime @default(now())
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id           String            @id @default(cuid())
  name         String?
  type         String            @default("direct")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     ChatMessage[]
  participants ChatParticipant[]
}

model ChatParticipant {
  id         String   @id @default(cuid())
  chatRoomId String
  userId     String
  joinedAt   DateTime @default(now())
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
}

model AttendanceLocation {
  id              String          @id @default(cuid())
  name            String
  latitude        Float
  longitude       Float
  radius          Float
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  locationClasses LocationClass[]
}

model LocationClass {
  id         String             @id @default(cuid())
  locationId String
  classId    String
  class      Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  location   AttendanceLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, classId])
}

model Attendance {
  id             String       @id @default(cuid())
  studentId      String
  academicYearId String
  date           DateTime
  timeIn         DateTime?
  timeOut        DateTime?
  status         String       @default("hadir")
  method         String?
  latitude       Float?
  longitude      Float?
  notes          String?
  createdBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student        Student      @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@index([studentId, date])
  @@index([academicYearId])
}

model LeaveRequest {
  id              String    @id @default(cuid())
  studentId       String
  type            String
  reason          String
  startDate       DateTime
  endDate         DateTime?
  evidenceUrl     String?
  status          String    @default("pending")
  approvedByWali  String?
  approvedByAdmin String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  student         Student   @relation("StudentLeaveRequest", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
}

model QRCode {
  id         String   @id @default(cuid())
  code       String   @unique
  validFrom  DateTime
  validUntil DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        String    @default("event")
  location    String?
  createdBy   String
  classId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  class       Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)
  creator     User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model LibraryBook {
  id          String              @id @default(cuid())
  title       String
  author      String?
  category    String?
  description String?
  fileUrl     String?
  coverUrl    String?
  isbn        String?
  publisher   String?
  year        Int?
  pages       Int?
  isAvailable Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  reviews     LibraryBookReview[]
}

model LibraryBookReview {
  id        String      @id @default(cuid())
  bookId    String
  userId    String
  rating    Int
  review    String?
  createdAt DateTime    @default(now())
  book      LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MediaItem {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int?
  folder    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id                       String   @id @default("settings")
  schoolName               String   @default("Sekolah")
  schoolLogoUrl            String?
  activeAcademicYearId     String?
  timeIn                   String   @default("07:00")
  timeLate                 String   @default("07:30")
  timeOutMin               String   @default("13:00")
  timeOutDeadline          String   @default("16:00")
  attendanceThreshold      Float    @default(80.0)
  faceRecognitionThreshold Float    @default(0.6)
  reminderMinutes          Int      @default(30)
  waEnabled                Boolean  @default(false)
  waApiUrl                 String   @default("https://waha.devlike.pro")
  waApiKey                 String?
  waSession                String   @default("default")
  waSenderNumber           String?
  waAutoAttendance         Boolean  @default(true)
  waAutoGrade              Boolean  @default(true)
  waAutoAnnouncement       Boolean  @default(true)
  waAutoLeaveRequest       Boolean  @default(true)
  emailEnabled             Boolean  @default(false)
  emailHost                String   @default("smtp.gmail.com")
  emailPort                Int      @default(587)
  emailSecure              Boolean  @default(false)
  emailUser                String?
  emailPass                String?
  emailFromName            String   @default("EduLMS")
  emailFromAddress         String?
  emailAutoAttendance      Boolean  @default(true)
  emailAutoGrade           Boolean  @default(true)
  emailAutoAnnouncement    Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  userRole  String
  action    String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentAuditLog {
  id            String   @id @default(cuid())
  studentId     String
  studentName   String
  changedBy     String
  changedByName String
  field         String
  oldValue      String?
  newValue      String?
  createdAt     DateTime @default(now())
  student       Student  @relation("StudentAuditLog", fields: [studentId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReportSchedule {
  id          String              @id @default(cuid())
  name        String
  type        String
  sendTime    String
  sendDay     String?
  recipient   String
  classFilter String?
  status      String              @default("active")
  template    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  logs        ReportScheduleLog[]
}

model ReportScheduleLog {
  id          String         @id @default(cuid())
  scheduleId  String
  sentAt      DateTime
  status      String
  totalSent   Int            @default(0)
  totalFailed Int            @default(0)
  details     String?
  createdAt   DateTime       @default(now())
  schedule    ReportSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}